{
  "manifest_version": 3,
  "name": "__DISPLAY_NAME__",
  "version": "__VERSION__",
  "description": "Save a LinkedIn profile to GuessWho, review a before/after diff, and apply the fields you choose.",
  "key": "__KEY__",

  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "64": "icon-64.png",
    "96": "icon-96.png",
    "128": "icon-128.png",
    "256": "icon-256.png",
    "512": "icon-512.png"
  },

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.licdn.com/*",
    "https://profiles.rice.edu/*",
    "http://127.0.0.1/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/in/*", "https://profiles.rice.edu/faculty/*", "https://profiles.rice.edu/staff/*"],
      "js": ["parse-profile.js", "content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "__DISPLAY_NAME__",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "64": "icon-64.png",
      "96": "icon-96.png",
      "128": "icon-128.png",
      "256": "icon-256.png",
      "512": "icon-512.png"
    }
  }
}
