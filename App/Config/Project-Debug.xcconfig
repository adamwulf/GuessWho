// Project-Debug.xcconfig
// PROJECT-level settings for the Debug configuration.

#include "Project-Shared.xcconfig"

// Per-configuration identifiers (Debug bundle id / App Group / iCloud container
// / entitlements) live in the per-target Debug xcconfigs — GuessWho-Debug.xcconfig
// and GuessWhoLinkedIn-Debug.xcconfig — which are wired as those targets' Debug
// baseConfigurationReference. Nothing identifier-related is set at this project
// level.

DEBUG_INFORMATION_FORMAT = dwarf
ENABLE_TESTABILITY = YES
ONLY_ACTIVE_ARCH = YES

// Optimization (off for debug)
GCC_DYNAMIC_NO_PIC = NO
GCC_OPTIMIZATION_LEVEL = 0
SWIFT_OPTIMIZATION_LEVEL = -Onone

// Debug compilation conditions / preprocessor
GCC_PREPROCESSOR_DEFINITIONS = DEBUG=1 $(inherited)
SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG $(inherited)

MTL_ENABLE_DEBUG_INFO = INCLUDE_SOURCE
