// GuessWho-Release.xcconfig
// Release-configuration identifiers for the GuessWho app target. Wired as the
// app target's Release baseConfigurationReference. Debug intentionally uses the
// same production identifiers so local builds exercise production capabilities.

#include "GuessWho-Shared.xcconfig"
// The CLI/MCP App Group derivation (GUESSWHO_CLI_APP_GROUP) — shared with the
// guesswho-cli helper target so app + helper always agree per channel (INV-4
// in plans/cli-mcp.md). Referenced by GuessWho-MacCatalyst.entitlements and
// the GuessWhoCLIAppGroup Info.plist key.
#include "CLIAppGroup-Release.xcconfig"

// Bundle id
PRODUCT_BUNDLE_IDENTIFIER = com.milestonemade.guesswho

// Display name. Read via CFBundleDisplayName in GuessWho/Info.plist; the Debug
// counterpart is "GuessWho Debug".
GUESSWHO_DISPLAY_NAME = GuessWho

// LinkedIn-handoff wake scheme. Must match GUESSWHO_LINKEDIN_URL_SCHEME in
// GuessWhoLinkedIn-Release.xcconfig. Registered via CFBundleURLTypes and read
// at runtime via the GuessWhoLinkedInURLScheme Info.plist key. The Debug
// counterpart is "guesswho-linkedin-debug" so the Debug extension wakes the
// Debug app.
GUESSWHO_LINKEDIN_URL_SCHEME = guesswho-linkedin

// Chrome/Brave-extension handoff (Catalyst only). The port the app's loopback
// listener binds (LinkedInLocalhostReceiver) and the extension ids allowed to
// POST to it. Read at runtime via the GuessWhoChromeHandoffPort /
// GuessWhoChromeExtensionIDs Info.plist keys (ChromeHandoff). The extension's
// build script (App/GuessWhoChrome/build.sh) PARSES this file for the port, so
// there is no second copy to keep in sync. The id below is derived from
// App/GuessWhoChrome/keys/release.pub (build.sh prints it); after the first
// Chrome Web Store upload, APPEND the store-assigned id (comma-separated) so
// the store-installed extension may talk to the app too.
GUESSWHO_CHROME_HANDOFF_PORT = 57230
GUESSWHO_CHROME_EXTENSION_IDS = hckkbhkjpmolhnihnjeglnlkdknbeaha

// App Group identifier — DIFFERENT per platform (per Apple guidance):
//   * iOS/iPadOS: must be `group.`-prefixed (the only form iOS supports), and
//     requires provisioning (handled by REGISTER_APP_GROUPS in the shared file).
//   * Mac Catalyst: use the `<TeamID>.<name>` form. It is self-authorizing by
//     code signature, needs NO provisioning profile and NO developer-portal
//     registration, and avoids the macOS 15+ "access data from other
//     applications" prompt. This form is NOT supported on iOS.
// Read at runtime via the GuessWhoAppGroup Info.plist key (AppGroup.id).
GUESSWHO_APP_GROUP = group.com.milestonemade.guesswho
GUESSWHO_APP_GROUP[sdk=macosx*] = $(DEVELOPMENT_TEAM).com.milestonemade.guesswho

// iCloud ubiquity container id. Read at runtime via the GuessWhoiCloudContainer
// Info.plist key (ICloudContainer.id) so the entitlement and the runtime lookup
// never diverge.
GUESSWHO_ICLOUD_CONTAINER = iCloud.com.milestonemade.guesswho

// Entitlements — per-target, per-SDK. The Catalyst file uses the `<TeamID>.`
// App Group form; the iOS file uses the `group.` form.
CODE_SIGN_ENTITLEMENTS = GuessWho/GuessWho.entitlements
CODE_SIGN_ENTITLEMENTS[sdk=macosx*] = GuessWho/GuessWho-MacCatalyst.entitlements
