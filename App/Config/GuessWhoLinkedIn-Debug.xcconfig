// GuessWhoLinkedIn-Debug.xcconfig
// Debug-configuration identifiers for the GuessWhoLinkedIn Safari Web Extension
// target. Wired as the extension's Debug baseConfigurationReference. Debug uses
// the production bundle id, App Group, and entitlements so Xcode builds exercise
// the same Apple-approved capabilities as Release.

#include "GuessWhoLinkedIn-Shared.xcconfig"

// Bundle id — must stay prefixed by the app bundle id (…guesswho ⊃ …guesswho.safari).
PRODUCT_BUNDLE_IDENTIFIER = com.milestonemade.guesswho.safari

// Display name — "Debug"-suffixed so Safari's extension list, permission
// prompts, and toolbar tooltip make an Xcode-installed extension obvious.
// Feeds CFBundleDisplayName in GuessWhoLinkedIn/Info.plist AND the generated
// manifest.json name/default_title (see the "Generate manifest.json" build
// phase).
GUESSWHO_EXTENSION_DISPLAY_NAME = GuessWho LinkedIn Debug

// LinkedIn-handoff wake scheme — must match GUESSWHO_LINKEDIN_URL_SCHEME in
// GuessWho-Debug.xcconfig so the Debug extension wakes the Debug app. Read at
// runtime via the GuessWhoLinkedInURLScheme Info.plist key.
GUESSWHO_LINKEDIN_URL_SCHEME = guesswho-linkedin-debug

// App Group — shared with the Debug app. Must match GUESSWHO_APP_GROUP in
// GuessWho-Debug.xcconfig. DIFFERENT per platform.
GUESSWHO_APP_GROUP = group.com.milestonemade.guesswho
GUESSWHO_APP_GROUP[sdk=macosx*] = $(DEVELOPMENT_TEAM).com.milestonemade.guesswho

// Entitlements — App Group only (no iCloud, no Contacts). Match Release so the
// extension and containing app share the same approved App Group.
CODE_SIGN_ENTITLEMENTS = GuessWhoLinkedIn/GuessWhoLinkedIn.entitlements
CODE_SIGN_ENTITLEMENTS[sdk=macosx*] = GuessWhoLinkedIn/GuessWhoLinkedIn-MacCatalyst.entitlements
