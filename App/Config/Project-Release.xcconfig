// Project-Release.xcconfig
// PROJECT-level settings for the Release configuration.

#include "Project-Shared.xcconfig"

// No id suffix for Release: the bundle id, App Group, and iCloud container use
// the bare base ids. See GUESSWHO_ID_SUFFIX in Project-Debug.xcconfig.
GUESSWHO_ID_SUFFIX =

// Release uses the bare entitlement files (no "-Debug" infix). See
// GUESSWHO_ENTITLEMENTS_VARIANT in Project-Debug.xcconfig.
GUESSWHO_ENTITLEMENTS_VARIANT =

DEBUG_INFORMATION_FORMAT = dwarf-with-dsym
ENABLE_NS_ASSERTIONS = NO
MTL_ENABLE_DEBUG_INFO = NO
SWIFT_COMPILATION_MODE = wholemodule
