// GuessWho-Debug.xcconfig
// Debug-configuration identifiers for the GuessWho app target. Wired as the
// app target's Debug baseConfigurationReference. The app uses the production
// bundle id and entitlements in Debug so local Xcode builds exercise the same
// Apple-approved capabilities as Release.

#include "GuessWho-Shared.xcconfig"

// Bundle id
PRODUCT_BUNDLE_IDENTIFIER = com.milestonemade.guesswho

// Display name — "Debug"-suffixed so an Xcode-installed debug build is obvious
// on the Home Screen. Read via CFBundleDisplayName in GuessWho/Info.plist.
GUESSWHO_DISPLAY_NAME = GuessWho Debug

// LinkedIn-handoff wake scheme — Debug-distinct so the Debug extension's wake
// URL opens the Xcode-installed app build. Hyphenated (not ".debug") per
// URL-scheme convention. Must match GUESSWHO_LINKEDIN_URL_SCHEME in
// GuessWhoLinkedIn-Debug.xcconfig. Registered via CFBundleURLTypes and read at
// runtime via the GuessWhoLinkedInURLScheme Info.plist key.
GUESSWHO_LINKEDIN_URL_SCHEME = guesswho-linkedin-debug

// Chrome/Brave-extension handoff (Catalyst only). The port the app's loopback
// listener binds (LinkedInLocalhostReceiver) and the extension ids allowed to
// POST to it — Debug-distinct so a Debug extension can never reach the Release
// app. Read at runtime via the GuessWhoChromeHandoffPort /
// GuessWhoChromeExtensionIDs Info.plist keys (ChromeHandoff). The extension's
// build script (App/GuessWhoChrome/build.sh) PARSES this file for the port, so
// there is no second copy to keep in sync; the id is derived from
// App/GuessWhoChrome/keys/debug.pub (build.sh prints it).
GUESSWHO_CHROME_HANDOFF_PORT = 57231
GUESSWHO_CHROME_EXTENSION_IDS = alnaedlcjmeghdgbejppfmjgmhhoaami

// App Group identifier — matches Release so Debug uses the same approved
// capabilities and runtime storage path.
GUESSWHO_APP_GROUP = group.com.milestonemade.guesswho
GUESSWHO_APP_GROUP[sdk=macosx*] = $(DEVELOPMENT_TEAM).com.milestonemade.guesswho

// iCloud ubiquity container id. Read at runtime via the GuessWhoiCloudContainer
// Info.plist key (ICloudContainer.id).
GUESSWHO_ICLOUD_CONTAINER = iCloud.com.milestonemade.guesswho

// Entitlements — per-target, per-SDK. Match Release so Debug can exercise
// production-only capabilities such as Contacts notes access.
CODE_SIGN_ENTITLEMENTS = GuessWho/GuessWho.entitlements
CODE_SIGN_ENTITLEMENTS[sdk=macosx*] = GuessWho/GuessWho-MacCatalyst.entitlements
