// GuessWho-Shared.xcconfig
// Config-invariant TARGET-level settings for the GuessWho app target. The
// identifier settings that differ by configuration — bundle id, App Group,
// iCloud container, and entitlements file — live in GuessWho-Debug.xcconfig
// and GuessWho-Release.xcconfig, each of which #includes this file and is wired
// as that configuration's baseConfigurationReference in the project.

#include "SharedVersion.xcconfig"

// Identity (config-invariant part). PRODUCT_BUNDLE_IDENTIFIER is per-config and
// lives in GuessWho-Debug/Release.xcconfig.
PRODUCT_NAME = $(TARGET_NAME)

// Signing
DEVELOPMENT_TEAM = T68Z94627S
CODE_SIGN_STYLE = Automatic
// Authorize the App Group entitlement at runtime. Without this, macOS 15+
// treats a `group.`-prefixed container the process touches as unauthorized
// (entitlement not validated) and shows the "would like to access data from
// other applications" prompt. Setting this makes automatic signing fetch a
// provisioning profile that includes the app group, so the entitlement is
// validated and no prompt appears. Verify with:
//   sudo launchctl procinfo `pgrep GuessWho`  # expect "entitlements validated"
REGISTER_APP_GROUPS = YES

// NOTE: the App Group (GUESSWHO_APP_GROUP, per-platform), the iCloud container
// (GUESSWHO_ICLOUD_CONTAINER), the display name (GUESSWHO_DISPLAY_NAME), the
// LinkedIn-handoff wake scheme (GUESSWHO_LINKEDIN_URL_SCHEME), and
// CODE_SIGN_ENTITLEMENTS are all per-config and live in GuessWho-Debug.xcconfig
// / GuessWho-Release.xcconfig. The Swift code reads GUESSWHO_APP_GROUP via the
// GuessWhoAppGroup Info.plist key, GUESSWHO_ICLOUD_CONTAINER via
// GuessWhoiCloudContainer, and GUESSWHO_LINKEDIN_URL_SCHEME via
// GuessWhoLinkedInURLScheme, so the runtime identifiers always match the signed
// entitlement / registered URL type for the active configuration.

// Swift
SWIFT_VERSION = 6.0
SWIFT_EMIT_LOC_STRINGS = YES
ENABLE_PREVIEWS = YES

// Platforms / devices (iPhone + iPad + Mac Catalyst)
SDKROOT = iphoneos
SUPPORTED_PLATFORMS = iphoneos iphonesimulator macosx
IPHONEOS_DEPLOYMENT_TARGET = 17.0
MACOSX_DEPLOYMENT_TARGET = 14.0

// The "Embed CLI Frameworks" phase copies the helper's macOS package
// frameworks into Contents/Frameworks/CLI and re-signs them; the user
// script sandbox denies those writes even with the destination declared
// as an output (declared outputs are not treated as writable prefixes for
// directory trees). App target only — every other target keeps the
// project-level YES.
ENABLE_USER_SCRIPT_SANDBOXING = NO
TARGETED_DEVICE_FAMILY = 1,2
SUPPORTS_MACCATALYST = YES
SUPPORTS_MAC_DESIGNED_FOR_IPHONE_IPAD = NO

LD_RUNPATH_SEARCH_PATHS = $(inherited) @executable_path/Frameworks @executable_path/../Frameworks
LD_RUNPATH_SEARCH_PATHS[sdk=macosx*] = $(inherited) @executable_path/../Frameworks @loader_path/../Frameworks

// Info.plist
GENERATE_INFOPLIST_FILE = NO
INFOPLIST_FILE = GuessWho/Info.plist

// App icon (Xcode 26 Icon Composer .icon at GuessWho/AppIcon.icon)
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
