<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Debug variant of GuessWho-MacCatalyst.entitlements: the App Group and
     iCloud container carry the ".debug" suffix so a Debug Catalyst install
     never shares storage with a Release install. Selected by
     GUESSWHO_ENTITLEMENTS_VARIANT=-Debug in Project-Debug.xcconfig. -->
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.personal-information.addressbook</key>
	<true/>
	<key>com.apple.security.personal-information.calendars</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<!-- Mac Catalyst uses the <TeamID>.<name> App Group form: self-authorizing
		     by code signature, no provisioning/registration, avoids the macOS
		     "access data from other applications" prompt. iOS uses the
		     group.-prefixed form (see GuessWho-Debug.entitlements). Keep in sync
		     with GUESSWHO_APP_GROUP[sdk=macosx*] (resolved with
		     GUESSWHO_ID_SUFFIX=.debug) in GuessWho-Shared.xcconfig. -->
		<string>T68Z94627S.com.milestonemade.guesswho.debug</string>
	</array>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.com.milestonemade.guesswho.debug</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudDocuments</string>
	</array>
	<key>com.apple.developer.ubiquity-container-identifiers</key>
	<array>
		<string>iCloud.com.milestonemade.guesswho.debug</string>
	</array>
</dict>
</plist>
