{
  "manifest_version": 3,
  "name": "GuessWho LinkedIn",
  "version": "0.1",
  "description": "Save the LinkedIn profile you're viewing into GuessWho. Review a before/after diff in the app, then apply only the fields you choose.",

  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "64": "icon-64.png",
    "96": "icon-96.png",
    "128": "icon-128.png",
    "256": "icon-256.png",
    "512": "icon-512.png"
  },

  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.licdn.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/in/*"],
      "js": ["parse-profile.js", "content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "GuessWho",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "64": "icon-64.png",
      "96": "icon-96.png",
      "128": "icon-128.png",
      "256": "icon-256.png",
      "512": "icon-512.png"
    }
  }
}
