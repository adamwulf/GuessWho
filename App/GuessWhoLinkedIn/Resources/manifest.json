{
  "manifest_version": 3,
  "name": "GuessWho LinkedIn",
  "version": "0.1",
  "description": "Step-0 handoff spike: prove content -> background -> native -> app wake.",

  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.licdn.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/in/*"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "GuessWho"
  }
}
